model ContentTemplate {
  id          String      @id @default(cuid())
  name        String
  channel     ChannelType
  category    String?
  subject     String?
  body        String      @db.Text
  variables   String[]
  thumbnailUrl String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}


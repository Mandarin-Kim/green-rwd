// Green-RWD v2 Database Schema
// PostgreSQL on Neon, managed via Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙
// 1. AUTH & USER
// 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙

enum Role {
  ADMIN
  SPONSOR
  CRA
  USER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  role          Role       @default(USER)
  orgId         String?
  phone         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  accounts      Account[]
  sessions      Session[]
  org           Organization? @relation(fields: [orgId], references: [id])
  campaigns     Campaign[]
  reportOrders  ReportOrder[]
  notifications Notification[]
  auditLogs     AuditLog[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙
// 2. ORGANIZATION
// 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙

model Organization {
  id          String    @id @default(cuid())
  name        String
  bizNumber   String?   @unique
  plan        String    @default("FREE")
  creditBalance Int     @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  users       User[]
  campaigns   Campaign[]
  reportOrders ReportOrder[]
}

// 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙
// 3. CAMPAIGN
// 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙

enum CampaignStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SCHEDULED
  EXECUTING
  PAUSED
  COMPLETED
  CANCELLED
}

enum ChannelType {
  SMS
  LMS
  KAKAO
  EMAIL
  PUSH
}

model Campaign {
  id              String         @id @default(cuid())
  name            String
  description     String?        @db.Text
  status          CampaignStatus @default(DRAFT)
  channelType     ChannelType    @default(SMS)

  // Step 1: 毛陋漏铆聭聹
  objective       String?
  kpiTarget       Json?

  // Step 2: 铆聝聙锚虏聼
  segmentId       String?
  segment         Segment?       @relation(fields: [segmentId], references: [id])
  targetCount     Int            @default(0)

  // Step 3: 矛陆聵铆聟聬矛赂聽
  contentTitle    String?
  contentBody     String?        @db.Text
  contentJson     Json?
  templateId      String?

  // Step 4: 矛聺录矛聽聲
  scheduledAt     DateTime?
  sendingDays     Json?
  sendingTime     String?

  // Step 5: 锚虏聙矛聢聵/矛聤鹿矛聺赂
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?

  // A/B Testing
  abTestEnabled   Boolean        @default(false)
  abVariants      Json?

  // Relations
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  orgId           String?
  org             Organization?  @relation(fields: [orgId], references: [id])
  sendings        Sending[]
  analytics       CampaignAnalytics?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙
// 4. SEGMENT
// 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙

model Segment {
  id            String     @id @default(cuid())
  name          String
  description   String?    @db.Text
  filterJson    Json
  patientCount  Int        @default(0)
  tags          String[]
  status        String     @default("active")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  campaigns     Campaign[]
  patients      PatientSegment[]
}

model Patient {
  id            String     @id @default(cuid())
  externalId    String?    @unique
  gender        String?
  ageGroup      String?
  region        String?
  diagnosisCodes String[]
  drugCodes     String[]
  consentStatus String     @default("PENDING")
  consentDate   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  segments      PatientSegment[]
}

model PatientSegment {
  id         String   @id @default(cuid())
  patientId  String
  segmentId  String
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  segment    Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  matchScore Float?
  matchedAt  DateTime @default(now())

  @@unique([patientId, segmentId])
}

// 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙
// 5. SENDING
// 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙

enum SendingStatus {
  PENDING
  APPROVED
  REJECTED
  READY
  EXECUTING
  PAUSED
  COMPLETED
  FAILED
}

model Sending {
  id            String        @id @default(cuid())
  campaignId    String
  campaign      Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  totalCount    Int           @default(0)
  successCount  Int           @default(0)
  failCount     Int           @default(0)
  status        SendingStatus @default(PENDING)
  channel       ChannelType   @default(SMS)
  costPerUnit   Float         @default(0)
  totalCost     Float         @default(0)
  approvedBy    String?
  approvedAt    DateTime?
  executedAt    DateTime?
  completedAt   DateTime?
  errorLog      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙
// 6. CAMPAIGN ANALYTICS
// 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙

model CampaignAnalytics {
  id              String   @id @default(cuid())
  campaignId      String   @unique
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  totalSent       Int      @default(0)
  delivered       Int      @default(0)
  opened          Int      @default(0)
  clicked         Int      @default(0)
  converted       Int      @default(0)
  bounced         Int      @default(0)
  unsubscribed    Int      @default(0)
  deliveryRate    Float    @default(0)
  openRate        Float    @default(0)
  clickRate       Float    @default(0)
  conversionRate  Float    @default(0)
  totalCost       Float    @default(0)
  costPerConvert  Float    @default(0)
  dailyStats      Json?
  hourlyStats     Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙
// 7. AI REPORT
// 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙

enum ReportTier {
  BASIC
  PRO
  PREMIUM
}

enum ReportStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
  CANCELLED
}

model ReportCatalog {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  description     String?       @db.Text
  categories      String[]
  therapeuticArea String?
  drugName        String?
  indication      String?
  region          String        @default("KR")
  marketSizeKrw   BigInt?
  patientPool     Int?
  availableTiers  ReportTier[]
  priceBasic      Int           @default(500000)
  pricePro        Int           @default(1500000)
  pricePremium    Int           @default(3000000)
  sampleUrl       String?
  thumbnailUrl    String?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  orders          ReportOrder[]
}

model ReportOrder {
  id              String       @id @default(cuid())
  catalogId       String
  catalog         ReportCatalog @relation(fields: [catalogId], references: [id])
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  orgId           String?
  org             Organization? @relation(fields: [orgId], references: [id])
  tier            ReportTier
  price           Int
  status          ReportStatus @default(PENDING)
  progress        Int          @default(0)
  customPrompt    String?      @db.Text
  sections        Json?
  generatedUrl    String?
  errorMessage    String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

// 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙
// 8. DATA SOURCE (矛聤陇铆聛卢毛聻聵铆聲聭/API 矛聴掳毛聫聶)
// 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙

enum DataSourceType {
  API
  SCRAPING
  CSV
  INTERNAL
}

model DataSource {
  id            String         @id @default(cuid())
  name          String
  type          DataSourceType
  endpoint      String?
  apiKey        String?
  schedule      String?
  lastSyncAt    DateTime?
  lastSyncStatus String?
  recordCount   Int            @default(0)
  isActive      Boolean        @default(true)
  config        Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  cacheEntries  DataCache[]
}

model DataCache {
  id           String     @id @default(cuid())
  sourceId     String
  source       DataSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  cacheKey     String
  data         Json
  expiresAt    DateTime
  createdAt    DateTime   @default(now())

  @@unique([sourceId, cacheKey])
  @@index([expiresAt])
}

// 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙
// 9. eClinical (CTMS / EDC)
// 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙

enum StudyStatus {
  PLANNING
  ACTIVE
  PAUSED
  COMPLETED
  TERMINATED
}

model Study {
  id              String       @id @default(cuid())
  protocolNumber  String       @unique
  title           String
  phase           String?
  status          StudyStatus  @default(PLANNING)
  sponsorName     String?
  indication      String?
  targetEnrollment Int         @default(0)
  currentEnrollment Int        @default(0)
  startDate       DateTime?
  endDate         DateTime?
  sites           Site[]
  ecrfTemplates   EcrfTemplate[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Site {
  id            String   @id @default(cuid())
  studyId       String
  study         Study    @relation(fields: [studyId], references: [id], onDelete: Cascade)
  name          String
  code          String
  piName        String?
  address       String?
  targetCount   Int      @default(0)
  enrolledCount Int      @default(0)
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EcrfTemplate {
  id         String   @id @default(cuid())
  studyId    String
  study      Study    @relation(fields: [studyId], references: [id], onDelete: Cascade)
  name       String
  version    String   @default("1.0")
  schema     Json
  isPublished Boolean @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}


// Green-RWD v2 Database Schema
// PostgreSQL on Neon, managed via Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ──────────────────────────────────────
// 1. AUTH & USER
// ──────────────────────────────────────

enum Role {
  ADMIN
  SPONSOR
  CRA
  USER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  role          Role       @default(USER)
  orgId         String?
  phone         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  accounts      Account[]
  sessions      Session[]
  org           Organization? @relation(fields: [orgId], references: [id])
  campaigns     Campaign[]
  reportOrders  ReportOrder[]
  notifications Notification[]
  auditLogs     AuditLog[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────────────────
// 2. ORGANIZATION
// ──────────────────────────────────────

model Organization {
  id          String    @id @default(cuid())
  name        String
  bizNumber   String?   @unique
  plan        String    @default("FREE")
  creditBalance Int     @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  users       User[]
  campaigns   Campaign[]
  reportOrders ReportOrder[]
}

// ──────────────────────────────────────
// 3. CAMPAIGN
// ──────────────────────────────────────

enum CampaignStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SCHEDULED
  EXECUTING
  PAUSED
  COMPLETED
  CANCELLED
}

enum ChannelType {
  SMS
  LMS
  KAKAO
  EMAIL
  PUSH
}

model Campaign {
  id              String         @id @default(cuid())
  name            String
  description     String?        @db.Text
  status          CampaignStatus @default(DRAFT)
  channelType     ChannelType    @default(SMS)

  // Step 1: 목표
  objective       String?
  kpiTarget       Json?

  // Step 2: 타겟
  segmentId       String?
  segment         Segment?       @relation(fields: [segmentId], references: [id])
  targetCount     Int            @default(0)

  // Step 3: 콘텐츠
  contentTitle    String?
  contentBody     String?        @db.Text
  contentJson     Json?
  templateId      String?

  // Step 4: 일정
  scheduledAt     DateTime?
  sendingDays     Json?
  sendingTime     String?

  // Step 5: 검수/승인
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?

  // A/B Testing
  abTestEnabled   Boolean        @default(false)
  abVariants      Json?

  // Relations
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  orgId           String?
  org             Organization?  @relation(fields: [orgId], references: [id])
  sendings        Sending[]
  analytics       CampaignAnalytics?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// ──────────────────────────────────────
// 4. SEGMENT
// ──────────────────────────────────────

model Segment {
  id            String     @id @default(cuid())
  name          String
  description   String?    @db.Text
  filterJson    Json
  patientCount  Int        @default(0)
  tags          String[]
  status        String     @default("active")
  // 보고서 연동: 어떤 보고서에서 생성되었는지
  catalogSlug   String?
  // 월별 중복 방지: "YYYY-MM" 형식 (예: "2026-04")
  sourceMonth   String?
  // 현재 활성 버전 번호
  currentVersion Int       @default(1)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  campaigns     Campaign[]
  patients      PatientSegment[]
  versions      SegmentVersion[]

  // 같은 보고서(catalogSlug) + 같은 월(sourceMonth)에 중복 생성 방지
  @@unique([catalogSlug, sourceMonth])
}

model SegmentVersion {
  id            String   @id @default(cuid())
  segmentId     String
  segment       Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  version       Int
  filterJson    Json
  patientCount  Int      @default(0)
  changeNote    String?  @db.Text
  createdAt     DateTime @default(now())

  @@unique([segmentId, version])
  @@index([segmentId])
}

model Patient {
  id            String     @id @default(cuid())
  externalId    String?    @unique
  gender        String?
  ageGroup      String?
  region        String?
  diagnosisCodes String[]
  drugCodes     String[]
  consentStatus String     @default("PENDING")
  consentDate   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  segments      PatientSegment[]
}

model PatientSegment {
  id         String   @id @default(cuid())
  patientId  String
  segmentId  String
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  segment    Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  matchScore Float?
  matchedAt  DateTime @default(now())

  @@unique([patientId, segmentId])
}

// ──────────────────────────────────────
// 5. SENDING
// ──────────────────────────────────────

enum SendingStatus {
  PENDING
  APPROVED
  REJECTED
  READY
  EXECUTING
  PAUSED
  COMPLETED
  FAILED
}

model Sending {
  id            String        @id @default(cuid())
  campaignId    String
  campaign      Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  totalCount    Int           @default(0)
  successCount  Int           @default(0)
  failCount     Int           @default(0)
  status        SendingStatus @default(PENDING)
  channel       ChannelType   @default(SMS)
  costPerUnit   Float         @default(0)
  totalCost     Float         @default(0)
  approvedBy    String?
  approvedAt    DateTime?
  executedAt    DateTime?
  completedAt   DateTime?
  errorLog      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// ──────────────────────────────────────
// 6. CAMPAIGN ANALYTICS
// ──────────────────────────────────────

model CampaignAnalytics {
  id              String   @id @default(cuid())
  campaignId      String   @unique
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  totalSent       Int      @default(0)
  delivered       Int      @default(0)
  opened          Int      @default(0)
  clicked         Int      @default(0)
  converted       Int      @default(0)
  bounced         Int      @default(0)
  unsubscribed    Int      @default(0)
  deliveryRate    Float    @default(0)
  openRate        Float    @default(0)
  clickRate       Float    @default(0)
  conversionRate  Float    @default(0)
  totalCost       Float    @default(0)
  costPerConvert  Float    @default(0)
  dailyStats      Json?
  hourlyStats     Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ──────────────────────────────────────
// 7. AI REPORT
// ──────────────────────────────────────

enum ReportTier {
  BASIC
  PRO
  PREMIUM
}

enum ReportStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
  CANCELLED
}

model ReportCatalog {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  description     String?       @db.Text
  categories      String[]
  therapeuticArea String?
  drugName        String?
  indication      String?
  region          String        @default("KR")
  marketSizeKrw   BigInt?
  patientPool     Int?
  availableTiers  ReportTier[]
  priceBasic      Int           @default(500000)
  pricePro        Int           @default(1500000)
  pricePremium    Int           @default(3000000)
  sampleUrl       String?
  thumbnailUrl    String?
  isActive        Boolean       @default(true)
  hiraData        Json?         // HIRA 실측 데이터 캐시 (HiraEnrichmentResult)
  clinicalTrialsData Json?      // ClinicalTrials.gov 데이터 캐시 (ClinicalTrialsData)
  pubMedData      Json?         // PubMed 논문 데이터 캐시 (PubMedSearchResult)
  dataSyncedAt    DateTime?     // 마지막 데이터 동기화 시각
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  orders          ReportOrder[]
}

model ReportOrder {
  id              String       @id @default(cuid())
  catalogId       String
  catalog         ReportCatalog @relation(fields: [catalogId], references: [id])
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  orgId           String?
  org             Organization? @relation(fields: [orgId], references: [id])
  tier            ReportTier
  price           Int
  status          ReportStatus @default(PENDING)
  progress        Int          @default(0)
  customPrompt    String?      @db.Text
  sections        Json?
  generatedUrl    String?
  errorMessage    String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

// ──────────────────────────────────────
// 8. DATA SOURCE (스크래핑/API 연동)
// ──────────────────────────────────────

enum DataSourceType {
  API
  SCRAPING
  CSV
  INTERNAL
}

model DataSource {
  id            String         @id @default(cuid())
  name          String
  type          DataSourceType
  endpoint      String?
  apiKey        String?
  schedule      String?
  lastSyncAt    DateTime?
  lastSyncStatus String?
  recordCount   Int            @default(0)
  isActive      Boolean        @default(true)
  config        Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  cacheEntries  DataCache[]
}

model DataCache {
  id           String     @id @default(cuid())
  sourceId     String
  source       DataSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  cacheKey     String
  data         Json
  expiresAt    DateTime
  createdAt    DateTime   @default(now())

  @@unique([sourceId, cacheKey])
  @@index([expiresAt])
}

// ──────────────────────────────────────
// 9. eClinical (CTMS / EDC)
// ──────────────────────────────────────

enum StudyStatus {
  PLANNING
  ACTIVE
  PAUSED
  COMPLETED
  TERMINATED
}

model Study {
  id              String       @id @default(cuid())
  protocolNumber  String       @unique
  title           String
  phase           String?
  status          StudyStatus  @default(PLANNING)
  sponsorName     String?
  indication      String?
  targetEnrollment Int         @default(0)
  currentEnrollment Int        @default(0)
  startDate       DateTime?
  endDate         DateTime?
  sites           Site[]
  ecrfTemplates   EcrfTemplate[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Site {
  id            String   @id @default(cuid())
  studyId       String
  study         Study    @relation(fields: [studyId], references: [id], onDelete: Cascade)
  name          String
  code          String
  piName        String?
  address       String?
  targetCount   Int      @default(0)
  enrolledCount Int      @default(0)
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EcrfTemplate {
  id         String   @id @default(cuid())
  studyId    String
  study      Study    @relation(fields: [studyId], references: [id], onDelete: Cascade)
  name       String
  version    String   @default("1.0")
  schema     Json
  isPublished Boolean @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ──────────────────────────────────────
// 10. NOTIFICATION & AUDIT
// ──────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String   @db.Text
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  detail    Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId, createdAt])
}

// ──────────────────────────────────────
// 11. TEMPLATE (캠페인 콘텐츠 템플릿)
// ──────────────────────────────────────

model ContentTemplate {
  id          String      @id @default(cuid())
  name        String
  channel     ChannelType
  category    String?
  subject     String?
  body        String      @db.Text
  variables   String[]
  thumbnailUrl String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// ──────────────────────────────────────
// 12. CREDIT & BILLING
// ──────────────────────────────────────

model CreditTransaction {
  id          String   @id @default(cuid())
  orgId       String
  type        String   // CHARGE, SPEND, REFUND
  amount      Int
  balance     Int
  description String?
  reference   String?
  createdAt   DateTime @default(now())
}

// ══════════════════════════════════════════════════════════
// 13. HIRA 공공데이터 DB 캐싱 (12개 API, 52 엔드포인트)
// ══════════════════════════════════════════════════════════

// ── 동기화 관리 (전체 API 공통) ──

enum HiraSyncStatus {
  IDLE
  SYNCING
  SUCCESS
  FAILED
}

/// HIRA API 동기화 이력 관리
model HiraSyncLog {
  id            String         @id @default(cuid())
  apiName       String
  operation     String
  status        HiraSyncStatus @default(IDLE)
  recordCount   Int            @default(0)
  params        Json?
  errorMessage  String?        @db.Text
  startedAt     DateTime?
  completedAt   DateTime?
  nextSyncAt    DateTime?
  createdAt     DateTime       @default(now())

  @@index([apiName, operation])
  @@index([status])
}

// ── B-1. 의약품사용정보 (12 엔드포인트) ──

model HiraDrugUsage {
  id              String   @id @default(cuid())
  diagYm          String
  analysisType    String
  componentCode   String?
  componentName   String?
  targetCode      String?
  targetName      String?
  usageAmount     Float    @default(0)
  usageRate       Float    @default(0)
  patientCount    Int      @default(0)
  claimAmount     BigInt   @default(0)
  rawData         Json?
  syncedAt        DateTime @default(now())

  @@unique([diagYm, analysisType, componentCode, targetCode])
  @@index([diagYm])
  @@index([analysisType])
  @@index([componentCode])
  @@index([targetCode])
}

// ── B-2. 질병정보 (5 엔드포인트) ──

model HiraDisease {
  id              String   @id @default(cuid())
  diseaseCode     String   @unique
  diseaseName     String
  diseaseEngName  String?
  patientCount    Int      @default(0)
  visitCount      Int      @default(0)
  claimAmount     BigInt   @default(0)
  syncedAt        DateTime @default(now())

  genderStats     HiraDiseaseGenderStats[]
  ageStats        HiraDiseaseAgeStats[]
  yearTrends      HiraDiseaseYearTrend[]
  areaStats       HiraDiseaseAreaStats[]
}

model HiraDiseaseGenderStats {
  id              String      @id @default(cuid())
  diseaseCode     String
  disease         HiraDisease @relation(fields: [diseaseCode], references: [diseaseCode], onDelete: Cascade)
  period          String
  gender          String
  inpatientCount  Int         @default(0)
  outpatientCount Int         @default(0)
  totalCount      Int         @default(0)
  syncedAt        DateTime    @default(now())

  @@unique([diseaseCode, period, gender])
}

model HiraDiseaseAgeStats {
  id              String      @id @default(cuid())
  diseaseCode     String
  disease         HiraDisease @relation(fields: [diseaseCode], references: [diseaseCode], onDelete: Cascade)
  period          String
  gender          String
  ageGroup        String
  patientCount    Int         @default(0)
  visitCount      Int         @default(0)
  claimAmount     BigInt      @default(0)
  syncedAt        DateTime    @default(now())

  @@unique([diseaseCode, period, gender, ageGroup])
  @@index([diseaseCode, period])
}

model HiraDiseaseYearTrend {
  id              String      @id @default(cuid())
  diseaseCode     String
  disease         HiraDisease @relation(fields: [diseaseCode], references: [diseaseCode], onDelete: Cascade)
  year            String
  patientCount    Int         @default(0)
  visitCount      Int         @default(0)
  claimAmount     BigInt      @default(0)
  avgClaimPerPt   Int         @default(0)
  syncedAt        DateTime    @default(now())

  @@unique([diseaseCode, year])
}

model HiraDiseaseAreaStats {
  id              String      @id @default(cuid())
  diseaseCode     String
  disease         HiraDisease @relation(fields: [diseaseCode], references: [diseaseCode], onDelete: Cascade)
  period          String
  regionCode      String
  regionName      String
  patientCount    Int         @default(0)
  visitCount      Int         @default(0)
  claimAmount     BigInt      @default(0)
  patientRate     Float       @default(0)
  syncedAt        DateTime    @default(now())

  @@unique([diseaseCode, period, regionCode])
  @@index([regionCode])
}

// ── B-3. 진료행위정보 (4 엔드포인트) ──

model HiraActionStats {
  id              String   @id @default(cuid())
  actionCode      String
  actionName      String?
  period          String
  analysisType    String
  targetCode      String?
  targetName      String?
  patientCount    Int      @default(0)
  frequency       Int      @default(0)
  claimAmount     BigInt   @default(0)
  rawData         Json?
  syncedAt        DateTime @default(now())

  @@unique([actionCode, period, analysisType, targetCode])
  @@index([actionCode])
  @@index([period])
}

// ── B-4. 수가기준정보 (3 엔드포인트) ──

model HiraMedicalFee {
  id              String   @id @default(cuid())
  feeCode         String
  feeName         String
  feeDivNo        String?
  category        String
  payTypeName     String?
  unitPrice       Int      @default(0)
  relativeValue   Float    @default(0)
  effectiveDate   String?
  syncedAt        DateTime @default(now())

  @@unique([feeCode, category])
  @@index([category])
  @@index([feeName])
}

// ── B-5. 병원정보 (1 엔드포인트) ──

model HiraHospital {
  id              String   @id @default(cuid())
  ykiho           String   @unique
  hospitalName    String
  classCode       String?
  className       String?
  sidoCode        String?
  sidoName        String?
  sgguCode        String?
  sgguName        String?
  address         String?
  phone           String?
  website         String?
  establishDate   String?
  doctorTotal     Int      @default(0)
  mdSpecialist    Int      @default(0)
  dtSpecialist    Int      @default(0)
  cmSpecialist    Int      @default(0)
  syncedAt        DateTime @default(now())

  facility        HiraFacilityDetail?
  departments     HiraHospitalDepartment[]
  equipment       HiraHospitalEquipment[]

  @@index([sidoCode])
  @@index([classCode])
  @@index([hospitalName])
}

// ── B-6. 약국정보 (1 엔드포인트) ──

model HiraPharmacy {
  id              String   @id @default(cuid())
  ykiho           String   @unique
  pharmacyName    String
  classCode       String?
  className       String?
  sidoCode        String?
  sidoName        String?
  sgguCode        String?
  sgguName        String?
  address         String?
  phone           String?
  establishDate   String?
  syncedAt        DateTime @default(now())

  @@index([sidoCode])
  @@index([pharmacyName])
}

// ── B-7. 의료기관별상세정보 (11 엔드포인트) ──

model HiraFacilityDetail {
  id              String       @id @default(cuid())
  ykiho           String       @unique
  hospital        HiraHospital @relation(fields: [ykiho], references: [ykiho], onDelete: Cascade)
  totalBeds       Int          @default(0)
  icuBeds         Int          @default(0)
  operatingRooms  Int          @default(0)
  nursingGrade    String?
  parkingCount    Int          @default(0)
  weekdayOpen     String?
  weekdayClose    String?
  satOpen         String?
  satClose        String?
  rawData         Json?
  syncedAt        DateTime     @default(now())
}

model HiraHospitalDepartment {
  id              String       @id @default(cuid())
  ykiho           String
  hospital        HiraHospital @relation(fields: [ykiho], references: [ykiho], onDelete: Cascade)
  departmentCode  String
  departmentName  String
  syncedAt        DateTime     @default(now())

  @@unique([ykiho, departmentCode])
}

model HiraHospitalEquipment {
  id              String       @id @default(cuid())
  ykiho           String
  hospital        HiraHospital @relation(fields: [ykiho], references: [ykiho], onDelete: Cascade)
  equipmentName   String
  equipmentCode   String?
  equipmentCount  Int          @default(1)
  syncedAt        DateTime     @default(now())

  @@unique([ykiho, equipmentName])
}

// ── B-8. 약가기준정보 (2 엔드포인트) ──

model HiraDrugPrice {
  id              String   @id @default(cuid())
  productCode     String
  productName     String
  manufacturer    String?
  category        String
  specification   String?
  dosageRoute     String?
  payType         String?
  unitPrice       Int      @default(0)
  upperLimit      Int      @default(0)
  mainIngredientCode String?
  effectiveDate   String?
  syncedAt        DateTime @default(now())

  @@unique([productCode, category])
  @@index([productName])
  @@index([manufacturer])
  @@index([mainIngredientCode])
}

// ── B-9. 비급여진료비정보 (7 엔드포인트) ──

model HiraNonPaymentItem {
  id              String   @id @default(cuid())
  itemCode        String   @unique
  itemName        String
  categoryCode    String?
  categoryName    String?
  syncedAt        DateTime @default(now())

  hospitalPrices  HiraNonPaymentPrice[]
  classStats      HiraNonPaymentClassStats[]
  regionStats     HiraNonPaymentRegionStats[]
}

model HiraNonPaymentPrice {
  id              String              @id @default(cuid())
  itemCode        String
  item            HiraNonPaymentItem  @relation(fields: [itemCode], references: [itemCode], onDelete: Cascade)
  ykiho           String
  hospitalName    String?
  className       String?
  sidoName        String?
  price           Int        @default(0)
  minPrice        Int        @default(0)
  maxPrice        Int        @default(0)
  syncedAt        DateTime   @default(now())

  @@unique([itemCode, ykiho])
  @@index([itemCode])
}

model HiraNonPaymentClassStats {
  id              String              @id @default(cuid())
  itemCode        String
  item            HiraNonPaymentItem  @relation(fields: [itemCode], references: [itemCode], onDelete: Cascade)
  classCode       String
  className       String
  avgPrice        Int        @default(0)
  minPrice        Int        @default(0)
  maxPrice        Int        @default(0)
  hospitalCount   Int        @default(0)
  syncedAt        DateTime   @default(now())

  @@unique([itemCode, classCode])
}

model HiraNonPaymentRegionStats {
  id              String              @id @default(cuid())
  itemCode        String
  item            HiraNonPaymentItem  @relation(fields: [itemCode], references: [itemCode], onDelete: Cascade)
  sidoCode        String
  sidoName        String
  avgPrice        Int        @default(0)
  minPrice        Int        @default(0)
  maxPrice        Int        @default(0)
  hospitalCount   Int        @default(0)
  syncedAt        DateTime   @default(now())

  @@unique([itemCode, sidoCode])
}

// ── B-10. 의약품성분약효정보 (1 엔드포인트) ──

model HiraIngredient {
  id              String   @id @default(cuid())
  generalNameCode String   @unique
  generalName     String
  efficacyCode    String?
  efficacyName    String?
  content         String?
  dosageRoute     String?
  formCode        String?
  formName        String?
  syncedAt        DateTime @default(now())

  @@index([efficacyCode])
  @@index([generalName])
}

// ── B-11. DRG 별도보상항목 (4 엔드포인트) ──

model HiraDrgMdfee {
  id              String   @id @default(cuid())
  feeCode         String   @unique
  feeName         String
  referenceName   String?
  unitPrice       Int      @default(0)
  effectiveDate   String?
  payType         String?
  syncedAt        DateTime @default(now())
}

model HiraDrgMaterial {
  id              String   @id @default(cuid())
  materialCode    String   @unique
  materialName    String
  categoryCode    String?
  categoryName    String?
  unitPrice       Int      @default(0)
  manufacturer    String?
  payType         String?
  syncedAt        DateTime @default(now())

  @@index([categoryCode])
}

// ── B-12. 신포괄기준정보 (1 엔드포인트) ──

model HiraNdrgItem {
  id              String   @id @default(cuid())
  classCode       String
  className       String?
  itemType        String?
  inclusionCode   String?
  inclusionName   String?
  startDate       String?
  endDate         String?
  isActive        Boolean  @default(true)
  syncedAt        DateTime @default(now())

  @@unique([classCode, itemType])
  @@index([itemType])
  @@index([isActive])
}
